# =============================================================
# AI-Franchise Growth OS — 生产环境配置模板
# =============================================================
# 将此文件复制为 .env 后填入实际值
# 注意：.env 文件已被 .gitignore 忽略，不会提交到代码仓库
# =============================================================

# ── 数据库 ──
# PostgreSQL 连接字符串（必填）
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://franchise_user:YOUR_PASSWORD@localhost:5432/ai_franchise?schema=public"

# ── 服务配置 ──
NODE_ENV=production
PORT=3000

# ── AI 模型 ──
# OpenAI API Key（应用内可通过"我的 > AI 大模型与知识库"页面设置）
# 此处为默认 fallback，优先级低于数据库中的 AiModelConfig 设置
OPENAI_API_KEY="sk-your-openai-api-key"

# ── 公共 URL ──
# 部署后的公网访问地址，用于 SSE 回调和内部调用
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# ── Cron Worker ──
# 设为 false 可关闭自主招商引擎的定时任务
CRON_WORKER_ENABLED=true

# ── 企业微信集成（可选） ──
WECOM_CORP_ID=""
WECOM_AGENT_ID=""
WECOM_SECRET=""
WECOM_TOKEN=""
WECOM_ENCODING_AES_KEY=""

# ── CRM / 有赞集成（可选，也可在页面中配置） ──
YOUZAN_APP_ID=""
YOUZAN_APP_SECRET=""
